# Web3Forms access key for the contact form (delivers to support@vyrapath.com).
# Get yours at https://web3forms.com — set recipient to support@vyrapath.com in the dashboard.
# VITE_ prefix is required so the browser can submit directly (server-side calls are blocked by Web3Forms/Cloudflare).
VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here
